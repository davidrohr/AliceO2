digraph "list"
{
 // INTERACTIVE_SVG=YES
  bgcolor="transparent";
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="{list\n||}",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black"];
  Node2 -> Node1 [color="grey25",fontsize="10",style="solid",label=" +first\n+last" ,arrowhead="odiamond",fontname="Helvetica"];
  Node2 [label="{list_node\n||}",height=0.2,width=0.4,color="black",URL="$dc/d6f/structlist__node.html"];
  Node2 -> Node2 [color="grey25",fontsize="10",style="solid",label=" +previous\n+next" ,arrowhead="odiamond",fontname="Helvetica"];
  Node3 -> Node2 [color="grey25",fontsize="10",style="solid",label=" +data" ,arrowhead="odiamond",fontname="Helvetica"];
  Node3 [label="{void *\n||}",height=0.2,width=0.4,color="grey75"];
  Node4 -> Node1 [color="grey25",fontsize="10",style="solid",label=" +count\n+keysize" ,arrowhead="odiamond",fontname="Helvetica"];
  Node4 [label="{int\n||}",height=0.2,width=0.4,color="grey75"];
}
